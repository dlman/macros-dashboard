# ──────────────────────────────────────────────────────────────────────────────
# Local development credentials for macros-dashboard sync scripts
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Setup steps:
#   1. Create a WHOOP developer app at https://developer.whoop.com
#      Redirect URL: http://localhost:8080/callback
#   2. Fill in WHOOP_CLIENT_ID and WHOOP_CLIENT_SECRET below
#   3. Run: python scripts/whoop_auth.py
#      This opens a browser, completes OAuth, and prints your refresh token
#   4. Paste the refresh token into WHOOP_REFRESH_TOKEN below
#   5. Run: python scripts/dev_sync.py
#      The refresh token rotates automatically on every run.
# ──────────────────────────────────────────────────────────────────────────────

WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
WHOOP_REFRESH_TOKEN=your_refresh_token_here

# Optional: set your local timezone if different from America/New_York
# WHOOP_TIMEZONE=America/Los_Angeles
